generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Publisher {
  id               String   @id @default(cuid())
  name             String
  domain           String   @unique
  website          String
  logoUrl          String?
  faviconUrl       String?
  colorHex         String?
  followersLabel   String?
  credibilityScore Float    @default(0.8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  articles News[]

  @@index([name])
}

model Topic {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  articles News[]
}

model News {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  dek        String
  aiSummary  String
  articleUrl String   @unique

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  category   String
  filterTags String[] @default([])
  topics     Topic[]

  publishedAt DateTime
  upvotes     Int      @default(0)
  downvotes   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks NewsBookmark[]
  votes     NewsVote[]
  comments  NewsComment[]

  @@index([publishedAt])
  @@index([publisherId])
  @@index([category])
}

model NewsBookmark {
  id        String   @id @default(cuid())
  articleId String
  article   News     @relation(fields: [articleId], references: [id])
  clientId  String
  createdAt DateTime @default(now())

  @@unique([articleId, clientId])
}

model NewsVote {
  id        String   @id @default(cuid())
  articleId String
  article   News     @relation(fields: [articleId], references: [id])
  clientId  String
  value     Int
  createdAt DateTime @default(now())

  @@unique([articleId, clientId])
}

model NewsComment {
  id         String   @id @default(cuid())
  articleId  String
  article    News     @relation(fields: [articleId], references: [id])
  clientId   String
  authorName String   @default("Anonymous")
  body       String
  createdAt  DateTime @default(now())

  @@index([articleId])
}
